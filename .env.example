# ──────────────────────────────────────────────
#  Néron Mobile — Template de configuration
# ──────────────────────────────────────────────
#  Copier ce fichier vers .env.local et renseigner vos valeurs.
#  NE PAS committer .env.local (il contient des secrets).
# ──────────────────────────────────────────────

# IP ou hostname du serveur Néron (ex: 192.168.1.100 ou homebox.local)
NEXT_PUBLIC_NERON_HOST=192.168.1.100

# Port WebSocket du gateway Néron (défaut: 18789)
NEXT_PUBLIC_NERON_PORT=18789

# URL WebSocket complète (générée depuis HOST + PORT)
NEXT_PUBLIC_NERON_WS_URL=ws://${NEXT_PUBLIC_NERON_HOST}:${NEXT_PUBLIC_NERON_PORT}

# Token d'authentification du gateway
NEXT_PUBLIC_NERON_TOKEN=changez_moi
